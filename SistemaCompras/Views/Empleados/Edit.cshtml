@model SistemaCompras.Models.Empleado
@using Microsoft.AspNetCore.Mvc.Rendering

<h1>Edit</h1>

<form asp-action="Edit">

    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="Cedula"></label>
        <input asp-for="Cedula" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Nombre"></label>
        <input asp-for="Nombre" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="DepartamentoId"></label>
        <select asp-for="DepartamentoId" class="form-control" asp-items="@(ViewData["DepartamentoId"] as SelectList)"></select>
    </div>

    <div class="form-group">
        <label asp-for="Estado"></label>
        <select asp-for="Estado" class="form-control">
            <option value="true">Activo</option>
            <option value="false">Inactivo</option>
        </select>
    </div>

    <br />
    <input type="submit" value="Save" class="btn btn-primary" />

</form>

<a asp-action="Index">Back to List</a>