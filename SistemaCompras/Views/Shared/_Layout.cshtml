<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Compras</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <!-- Bootstrap CSS (CDN) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- CSS del proyecto -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            font-family: 'Montserrat', sans-serif;
        }

        .navbar-brand {
            letter-spacing: 2px;
        }
    </style>
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-3 py-3">
            <div class="container">

                <a class="navbar-brand fw-light text-uppercase"
                   asp-controller="Home"
                   asp-action="Index">
                    SistemaCompras
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-end" id="navbarMenu">

                    <ul class="navbar-nav">

                        <li class="nav-item">
                            <a class="nav-link text-dark fw-light"
                               asp-controller="Home"
                               asp-action="Index">
                                INICIO
                            </a>
                        </li>

                        <!-- MANTENIMIENTOS -->

                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle text-dark fw-light"
                               href="#"
                               data-bs-toggle="dropdown">

                                MANTENIMIENTOS

                            </a>

                            <ul class="dropdown-menu shadow-sm border-0">

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Departamentos"
                                       asp-action="Index">
                                        Departamentos
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Empleados"
                                       asp-action="Index">
                                        Empleados
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Articulos"
                                       asp-action="Index">
                                        Artículos
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="UnidadMedidas"
                                       asp-action="Index">
                                        Unidades de Medida
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Marcas"
                                       asp-action="Index">
                                        Marcas
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Proveedores"
                                       asp-action="Index">
                                        Proveedores
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark fw-light" asp-controller="Account" asp-action="Logout">SALIR</a>
                                </li>


                            </ul>

                        </li>


                        <!-- PROCESOS -->

                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle text-dark fw-light"
                               href="#"
                               data-bs-toggle="dropdown">

                                PROCESOS

                            </a>

                            <ul class="dropdown-menu shadow-sm border-0">

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="SolicitudesCompra"
                                       asp-action="Index">
                                        Solicitudes de Compra
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="OrdenesCompra"
                                       asp-action="Index">
                                        Órdenes de Compra
                                    </a>
                                </li>

                            </ul>

                        </li>

                    </ul>

                </div>
            </div>
        </nav>
    </header>


    <main class="container">

        @RenderBody()

    </main>


    <footer class="border-top footer text-muted mt-5">
        <div class="container text-center small py-3">
            &copy; 2026 - Sistema de Compras
        </div>
    </footer>


    <!-- Bootstrap JS CDN -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>