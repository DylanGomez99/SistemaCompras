@model SistemaCompras.ViewModels.SolicitudCompraCreateViewModel

@{
    ViewData["Title"] = "Crear Solicitud";
}

<h1>Crear Solicitud de Artículos</h1>

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="EmpleadoId" class="form-label">Empleado Solicitante</label>
        <select asp-for="EmpleadoId" asp-items="Model.Empleados" class="form-control">
            <option value="">-- Seleccione empleado --</option>
        </select>
        <span asp-validation-for="EmpleadoId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Estado" class="form-label"></label>
        <select asp-for="Estado" class="form-control">
            <option value="Pendiente">Pendiente</option>
            <option value="Aprobada">Aprobada</option>
            <option value="Rechazada">Rechazada</option>
        </select>
        <span asp-validation-for="Estado" class="text-danger"></span>
    </div>

    <h4>Detalle</h4>

    <div id="detalles">
        @for (int i = 0; i < Model.Detalles.Count; i++)
        {
            <div class="row mb-2">
                <div class="col-md-4">
                    <select asp-for="Detalles[@i].ArticuloId" asp-items="Model.Articulos" class="form-control">
                        <option value="">-- Artículo --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <select asp-for="Detalles[@i].UnidadMedidaId" asp-items="Model.UnidadesMedida" class="form-control">
                        <option value="">-- Unidad de Medida --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <input asp-for="Detalles[@i].Cantidad" class="form-control" placeholder="Cantidad" />
                </div>
            </div>
        }
    </div>

    <button type="button" class="btn btn-secondary mb-3" onclick="agregarDetalle()">Agregar línea</button>
    <br />
    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script>
        let index = @Model.Detalles.Count;

        function agregarDetalle() {
            const container = document.getElementById("detalles");
            const html = `
                <div class="row mb-2">
                    <div class="col-md-4">
                        <select name="Detalles[${index}].ArticuloId" class="form-control">
                            <option value="">-- Artículo --</option>
                            @foreach (var item in Model.Articulos!)
                            {
                                <text><option value="@item.Value">@item.Text</option></text>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <select name="Detalles[${index}].UnidadMedidaId" class="form-control">
                            <option value="">-- Unidad de Medida --</option>
                            @foreach (var item in Model.UnidadesMedida!)
                            {
                                <text><option value="@item.Value">@item.Text</option></text>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <input name="Detalles[${index}].Cantidad" class="form-control" placeholder="Cantidad" />
                    </div>
                </div>
            `;
            container.insertAdjacentHTML("beforeend", html);
            index++;
        }
    </script>
}